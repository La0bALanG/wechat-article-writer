# 即梦 AI 文生图 API 配置
# 获取方式：访问 https://www.volcengine.com/ 开通即梦 AI 服务
VOLC_ACCESS_KEY=your_access_key_here
VOLC_SECRET_KEY=your_secret_key_here

# 微信公众号配置
# 获取方式：登录微信开放平台 https://open.weixin.qq.com/
WECHAT_APPID=your_appid_here
WECHAT_APPSECRET=your_appsecret_here

# Ziliu 智能排版 API 配置
# 获取方式：访问 https://ziliu.online/ 注册获取 API Key
ZILIU_API_KEY=your_ziliu_api_key_here
